# The bridge always binds to loopback. Tailscale Serve is the TLS ingress.
SHELTIE_PORT=9847
SHELTIE_INSTANCE_NAME="Mac Studio"
SHELTIE_INSTANCE_ID=mac-studio
SHELTIE_PUBLIC_HOST=mac-studio.example.ts.net
SHELTIE_EXPECTED_HOST=mac-studio.example.ts.net

# Comma-separated Tailscale user logins allowed to reach pairing and authenticated APIs.
SHELTIE_ALLOWED_TAILSCALE_LOGINS=you@example.com

# Optional overrides.
# HERDR_CONFIG_ROOT=/Users/you/.config/herdr
# HERDR_SOCKET_PATH=/Users/you/.config/herdr/herdr.sock
# HERDR_BINARY=/opt/homebrew/bin/herdr
# SHELTIE_DATA_DIR=/Users/you/.config/sheltie
# SHELTIE_SNAPSHOT_POLL_MS=2000
# SHELTIE_TERMINAL_POLL_MS=350

# Loopback-only local development. This enables `Authorization: Bearer development`.
# Never expose the bridge through Tailscale Serve while this is enabled.
# SHELTIE_DEV_MODE=1
